# Copy to .env and replace every change-me value. Never commit .env.

# Container image and host paths
AIRFLOW_IMAGE_NAME=wechat-on-airflow:3.3.0
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=.

# Airflow runtime
AIRFLOW_BASE_URL=http://localhost:8080
AIRFLOW_FERNET_KEY=change-me
AIRFLOW_API_SECRET_KEY=change-me
AIRFLOW_JWT_SECRET=change-me
# Must exceed the longest expected task runtime.
AIRFLOW_CELERY_VISIBILITY_TIMEOUT_SECONDS=86400

# Airflow administrator, used only by the explicit create-admin command
AIRFLOW_USERNAME=airflow
AIRFLOW_PASSWORD=change-me
AIRFLOW_EMAIL=airflow@example.com

# Metadata database
AIRFLOW_DATABASE_NAME=airflow
AIRFLOW_DATABASE_USERNAME=airflow
AIRFLOW_DATABASE_PASSWORD=change-me
# Used only by airflow-migrate. Keep above the current task_instance row count.
AIRFLOW_MIGRATION_BATCH_SIZE=20000000

# Independent synchronous WeChat sender
WECHAT_SENDER_IMAGE_NAME=wechat-sender:0.1.0
WECHAT_ALLOWED_DEVICE_NAME=change-me
WECHAT_APPIUM_URL=http://127.0.0.1:6002

# Remote production operations. Leave blank for local development.
SERVER_IP=
PORT=22
USERNAME=
PASSWORD=
REMOTE_PATH=/root/wechat-on-airflow
